# Leave blank for local dev (Vite proxy handles it automatically).
# For production (Vercel), set these to your Cloudflare tunnel URL.

# Root URL of your tunnel — no trailing slash
VITE_API_URL=https://your-tunnel.trycloudflare.com

# WebSocket URL of your tunnel
VITE_WS_URL=wss://your-tunnel.trycloudflare.com/ws
